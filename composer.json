{
    "name": "webcoast/migrator-from-flux",
    "type": "typo3-cms-extension",
    "description": "Flux provider for Migrator extension",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Thorben Nissen",
            "email": "thorben@webcoast.dk"
        }
    ],
    "extra": {
        "typo3/cms": {
            "extension-key": "migrator_from_flux"
        }
    },
    "require": {
        "fluidtypo3/flux": "^11.1",
        "typo3/cms-core": "^13.4",
        "symfony/dependency-injection": "^6.4 || ^7.4",
        "webcoast/migrator": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "WEBcoast\\MigratorFromFlux\\": "Classes"
        }
    }
}
